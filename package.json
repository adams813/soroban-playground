{
  "name": "soroban-playground",
  "version": "1.0.0",
  "description": "Browser-based IDE for compiling and deploying Soroban Smart Contracts to Stellar Testnet",
  "author": "Ayomide (Maintainer) & Open Source Contributors",
  "license": "MIT",
  "private": true,
  "overrides": {
    "graphql": "^16.13.2"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:check": "npm run lint:check --workspaces --if-present"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jest-environment-jsdom": "^30.4.1"
  }
}
